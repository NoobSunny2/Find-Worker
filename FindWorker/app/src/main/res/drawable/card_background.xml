<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background Color -->
    <solid android:color="@android:color/white" />

    <!-- Rounded Corners -->
    <corners android:radius="12dp" />

    <!-- Optional Stroke for better visibility -->
    <stroke
        android:width="1dp"
        android:color="#22000000" /> <!-- subtle shadowed border -->

    <!-- Padding inside the shape -->
    <padding
        android:left="16dp"
        android:top="12dp"
        android:right="16dp"
        android:bottom="12dp" />
</shape>

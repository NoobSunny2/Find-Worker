<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background Color -->
    <solid android:color="#FFFFFF" />

    <!-- Border -->
    <stroke
        android:width="1dp"
        android:color="@color/black" />

    <!-- Rounded Corners -->
    <corners android:radius="12dp" />

    <!-- Optional: Add Padding (inside shape, mostly aesthetic) -->
    <padding
        android:left="12dp"
        android:right="12dp"
        android:top="6dp"
        android:bottom="6dp" />
</shape>

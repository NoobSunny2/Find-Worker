<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".Homepage">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            >

            <ImageView
                android:id="@+id/location_icon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_location"
                 />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">


                <TextView
                    android:id="@+id/small_location"
                    android:text="Your Location"
                    android:textColor="#444"
                    android:maxLines="1"
                    android:textFontWeight="10"
                    android:ellipsize="end"
                    android:layout_height="match_parent"
                    android:layout_width="match_parent"
                    android:textSize="12sp"
                    android:fontFamily="@font/montserrat" />

                <TextView
                    android:id="@+id/location_text"
                    android:text="Set Location"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#000"
                    android:fontFamily="@font/poppins"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_height="match_parent"
                    android:layout_width="match_parent"/>

            </LinearLayout>
        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/searchCard"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="1dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:background="#F3F4F6">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:tint="@color/black" />

            <EditText
                android:id="@+id/searchView"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Search for 'Electrician'"
                android:textSize="15sp"
                android:textColor="#222"
                android:textColorHint="#9E9E9E"
                android:background="@android:color/transparent"
                android:paddingStart="10dp"
                android:fontFamily="@font/poppins"/>

            <ImageView
                android:id="@+id/btnMic"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_mic"
                app:tint="#FF5722" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/featureRecycler"
        android:layout_width="0dp"
        android:layout_margin="8dp"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/searchCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>



    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="#F6F7FB"
        app:layout_constraintTop_toBottomOf="@id/featureRecycler"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        >

        <!-- TABS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:background="@color/white"
            android:elevation="4dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tabFindWorkers"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Find Workers"
                android:textColor="#4A6CF7"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/tab_selected_underline"
                android:fontFamily="@font/poppins"/>

            <TextView
                android:id="@+id/tabMyBookings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="My Bookings"
                android:textStyle="bold"
                android:textColor="#999"
                android:textSize="16sp"
                android:fontFamily="@font/poppins"/>
        </LinearLayout>

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefreshLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/white"
                android:padding="8dp"
                android:clipToPadding="false" />
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- BOOKINGS LIST (Hidden by default) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/bookingsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp"
            android:clipToPadding="false"
            android:visibility="gone"/>

    </LinearLayout>



    <!-- EMPTY VIEW -->
    <TextView
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="No workers found"
        android:textSize="16sp"
        android:textColor="#999"
        android:fontFamily="@font/montserrat_bold"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/swipeRefreshLayout"
        app:layout_constraintBottom_toBottomOf="@id/swipeRefreshLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="NotSibling" />



    <!-- LOADING SPINNER -->
    <ProgressBar
        android:id="@+id/loading_spinner"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:indeterminate="true"
        android:visibility="gone"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/arrivalTracker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:orientation="horizontal"
        android:background="@drawable/tracker_background"
        android:gravity="center_vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        android:elevation="8dp">

        <!-- LEFT SIDE TEXT -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="1">

            <TextView
                android:id="@+id/trackerWorkerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Worker is on the way"
                android:textSize="17sp"
                android:textStyle="bold"
                android:fontFamily="@font/montserrat_bold"
                android:textColor="#000"/>

            <TextView
                android:id="@+id/trackerEta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Arriving in 12 mins"
                android:textSize="15sp"
                android:fontFamily="@font/montserrat_semibold"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/trackerOtp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start OTP: 1234"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FF5722"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/trackerStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accepted"
                android:fontFamily="@font/montserrat_bold"
                android:textSize="12sp"
                android:textColor="#777"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- VIEW BUTTON (RIGHT SIDE) -->
        <Button
            android:id="@+id/btnViewLive"
            android:layout_width="90dp"
            android:layout_height="38dp"
            android:text="VIEW"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:backgroundTint="#4A6CF7"
            android:elevation="4dp"
            android:padding="6dp"/>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCamera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/fabAssistant"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@android:drawable/ic_menu_camera"
        app:tint="@color/white"
        app:backgroundTint="#4CAF50"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAssistant"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/ic_assistant"
        app:tint="@color/white"
        app:backgroundTint="@color/black"/>


    <FrameLayout
        android:id="@+id/aiOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:clickable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Pulse Container -->
            <FrameLayout
                android:layout_width="140dp"
                android:layout_height="140dp">

                <!-- Pulse Ring -->
                <View
                    android:id="@+id/pulseRing"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:background="@drawable/pulse_circle"/>

                <ImageView
                    android:id="@+id/aiIcon"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_assistant"
                    app:tint="@color/white" />

            </FrameLayout>

            <TextView
                android:id="@+id/listeningText"
                android:layout_marginTop="20dp"
                android:text="Listening..."
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>

        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

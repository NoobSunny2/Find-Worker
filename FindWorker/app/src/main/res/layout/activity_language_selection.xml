<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FB"
    android:gravity="center"
    android:padding="24dp">

    <!-- App Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose Your Language"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#111111"
        android:fontFamily="@font/montserrat_bold"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select preferred language to continue"
        android:textSize="14sp"
        android:textColor="#777777"
        android:fontFamily="@font/montserrat"
        android:layout_marginBottom="32dp"/>

    <!-- Telugu Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/langTelugu"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E0E0E0"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:padding="18dp"
            android:background="@color/white"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/telugu"
                android:layout_marginEnd="18dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Telugu"
                android:textSize="18sp"
                android:textColor="#111111"
                android:fontFamily="@font/montserrat_semibold"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>


    <!-- Hindi Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/langHindi"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E0E0E0"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:padding="18dp"
            android:background="@color/white"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/hindi"
                android:layout_marginEnd="18dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hindi"
                android:textSize="18sp"
                android:textColor="#111111"
                android:fontFamily="@font/montserrat_semibold"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>


    <!-- English Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/langEnglish"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginBottom="32dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E0E0E0"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:padding="18dp"
            android:background="@color/white"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/english"
                android:layout_marginEnd="18dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="English"
                android:textSize="18sp"
                android:textColor="#111111"
                android:fontFamily="@font/montserrat_semibold"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>


    <!-- Next Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Continue"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:fontFamily="@font/montserrat_semibold"
        app:cornerRadius="30dp"
        android:backgroundTint="#FF5722"
        android:elevation="6dp"/>

</LinearLayout>
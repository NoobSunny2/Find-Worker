<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7FB"
    tools:context=".WorkerDetailsActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/workerToolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        android:elevation="6dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:title="Worker Details"
        app:titleTextColor="@color/black"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/detailsScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/workerToolbar"
        app:layout_constraintBottom_toTopOf="@id/bottomActionsLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="1dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_margin="12dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="10dp"
                android:foreground="?attr/selectableItemBackground"
                android:backgroundTint="@android:color/white">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- FULL IMAGE -->
                    <ImageView
                        android:id="@+id/workerImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/woker_image"/>

                    <!-- GRADIENT -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/gradient_overlay"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="10dp"
                        android:layout_gravity="top|start"
                        android:orientation="horizontal"
                        android:background="@drawable/rating_bg"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_star_rate"
                            app:tint="#FFB400"/>

                        <TextView
                            android:id="@+id/workerRatings"
                            android:text="4.5"
                            android:textSize="12sp"
                            android:textColor="#111"
                            android:layout_marginStart="4dp"
                            android:fontFamily="@font/montserrat_semibold"
                            android:layout_height="wrap_content"
                            android:layout_width="match_parent"
                            tools:ignore="DuplicateIds" />
                    </LinearLayout>

                    <!-- CONTENT -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <!-- NAME -->
                        <TextView
                            android:id="@+id/workerName"
                            android:text="Jerome Bell"
                            android:textSize="22sp"
                            android:layout_height="match_parent"
                            android:layout_width="match_parent"
                            android:textColor="@android:color/white"
                            android:fontFamily="@font/montserrat_bold"/>

                        <!-- PROFESSION -->
                        <TextView
                            android:id="@+id/workerProfession"
                            android:text="Electrician who focuses on safety and quality"
                            android:textSize="13sp"
                            android:textColor="#DDFFFFFF"
                            android:layout_height="match_parent"
                            android:layout_width="match_parent"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/poppins"/>

                        <TextView
                            android:id="@+id/workerLocation"
                            android:text="📍 Hyderabad"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins"/>

                        <TextView
                            android:id="@+id/workerJoinDate"
                            android:text="   Joined: Jan 2024"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:fontFamily="@font/poppins"/>

                    </LinearLayout>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/actionCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                android:backgroundTint="@color/white"
                >
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <!-- Title -->
                    <TextView
                        android:id="@+id/problemTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Describe Your Problem"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#111111"
                        android:fontFamily="@font/montserrat_semibold"
                        android:layout_marginBottom="0dp"/>

                    <!-- Problem Input Box (Multiline) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/problemInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="E.g., Fan not working, Plumbing issue..."
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/problemEditText"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:gravity="top|start"
                            android:inputType="textMultiLine"
                            android:maxLines="4"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:fontFamily="@font/montserrat"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Book Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/bookBtn"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="5dp"
                        android:text="Book Service Now"
                        android:textColor="@android:color/white"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/montserrat_semibold"
                        android:backgroundTint="@color/black"
                        app:cornerRadius="12dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <!-- TOGGLE BUTTONS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:background="@drawable/toggle_bg"
                android:padding="4dp">

                <TextView
                    android:id="@+id/btnReviews"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Reviews"
                    android:fontFamily="@font/montserrat_semibold"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/toggle_selected"/>

                <TextView
                    android:id="@+id/btnGiveRating"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:fontFamily="@font/montserrat_semibold"
                    android:text="Give Rating"
                    android:textStyle="bold"
                    android:textColor="#555"
                    android:background="@android:color/transparent"/>
            </LinearLayout>


            <androidx.cardview.widget.CardView
                android:id="@+id/reviewsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"

                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <TextView
                    android:id="@+id/txtNoFeedback"
                    android:text="No feedback yet. Be the first to add one ⭐"
                    android:gravity="center"
                    android:textColor="#777"
                    android:visibility="gone"
                    android:padding="16dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/feedbackRecycler"
                    android:padding="4dp"
                    android:background="#F6F7FB"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>


            </androidx.cardview.widget.CardView>



            <androidx.cardview.widget.CardView
                android:id="@+id/ratingCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:visibility="gone"
                app:cardCornerRadius="18dp"
                app:cardElevation="5dp"
                android:backgroundTint="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:text="Service Rating and Reviews"
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/montserrat_semibold"
                        android:layout_height="match_parent"
                        android:layout_width="match_parent"/>

                    <TextView
                        android:id="@+id/workerRating"
                        android:text="4.8 (42 reviews)"
                        android:textSize="18sp"
                        android:textColor="#FF9800"
                        android:layout_height="match_parent"
                        android:layout_width="match_parent"
                        android:fontFamily="@font/montserrat_bold"
                        android:layout_marginTop="6dp"/>

                    <RatingBar
                        android:id="@+id/ratingBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="5"
                        android:stepSize="0.5"
                        android:rating="0"

                        android:progressTint="@color/black"
                        android:isIndicator="false"
                        android:layout_marginTop="6dp"/>

                    <EditText
                        android:id="@+id/feedbackInput"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:hint="Write your feedback..."
                        android:background="@drawable/edittext_background"
                        android:gravity="top|start"
                        android:fontFamily="@font/montserrat"
                        android:padding="10dp"
                        android:textColor="#000"
                        android:textColorHint="#777"
                        android:layout_marginTop="10dp"/>

                    <Button
                        android:id="@+id/submitReviewBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Submit Review"
                        android:textColor="@color/white"
                        android:backgroundTint="#4CAF50"
                        android:paddingHorizontal="20dp"
                        android:fontFamily="@font/montserrat_semibold"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>



    <LinearLayout
        android:id="@+id/bottomActionsLayout"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:backgroundTint="#F4F5F7"
        android:gravity="center"
        android:padding="12dp"
        android:weightSum="2"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/whatsappBtn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="WhatsApp"
            android:textColor="@color/white"
            android:backgroundTint="#25D366"
            android:drawableStart="@drawable/ic_whatsapp"
            android:drawableTint="@color/white"
            android:drawablePadding="10dp"
            android:fontFamily="@font/montserrat_semibold"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/callBtn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Call Now"
            android:textColor="@color/white"
            android:backgroundTint="#007AFF"
            android:drawableStart="@drawable/ic_call"
            android:drawableTint="@color/white"
            android:drawablePadding="10dp"
            android:fontFamily="@font/montserrat_semibold"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
